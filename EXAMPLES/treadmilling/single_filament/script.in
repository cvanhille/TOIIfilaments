log                 log.out
units               lj
dimension           2
atom_style          molecular
read_data           config.in   extra/bond/per/atom 5  extra/special/per/atom 20  extra/angle/per/atom 3

# Required per-atom custom properties for fix_treadmilling
# - d_birth_time : double storing the creation timestep of a monomer
# - i_filpos     : integer flag describing role in filament (0=bulk,1=head,2=subhead,3=tail,4=dimer tail)
fix  prop1 all property/atom d_birth_time ghost yes
fix  prop2 all property/atom i_filpos ghost yes

# Initialize all birth times to zero for initial atoms
set atom * d_birth_time 0.0

# Set atom-specific filpos values 
set atom 1 i_filpos 1
set atom 2 i_filpos 4

variable            rmin equal 1.12246204831                      # LJ minimum distance
variable            eps equal 5.00                                # LJ attraction strength [kT]
variable            Kbond equal 1000.0                            # bond constant [kT/sigma2]
variable            Kbend equal 800.0                             # bend constant [kT/sigma2]
variable            tstep equal 0.001000                          # simulation timestep size [seconds]
variable            run_time equal 600.0                          # simulation run time [seconds] 45.0 #
variable            frame_rate equal 0.01 #0.5 #1.0                          # dumping interval [seconds]
variable            seed equal 1234                               # random number generator seed

variable            rstep equal 1.0/${tstep}                      # reaction interval [simulation steps]
variable            run_steps equal ${run_time}/${tstep}          # simulation run time [simulation steps]
variable            dump_time equal ${frame_rate}/${tstep}        # dumping interval [simulation steps]

# Treadmilling kinetic parameters (example values)
variable r_on    equal 1000.00
variable r_off   equal 0.00
variable r_hyd   equal 0.1
variable r_nuc   equal 0.0
variable sigma_tm equal 1.0
variable noise_tm equal 0.00
variable maxtrials equal 100
variable overlap_tm equal 0.9
variable ptype_tm equal 1
variable btype_tm equal 1
variable atype_tm equal 1
variable seed_tm equal 12345

#special_bonds       lj 1.0 1.0 1.0
special_bonds       lj 0.0 0.0 0.0

bond_style          harmonic
bond_coeff          1 ${Kbond} 1.0

angle_style         harmonic
angle_coeff         * ${Kbend} 180.0

pair_style          lj/cut 2.50
pair_coeff          1 1 ${eps} 1.00 ${rmin}

# Treadmilling dynamics (nevery = ${rstep} timesteps)
fix                 fTread all treadmilling ${rstep} r_on ${r_on} r_off ${r_off} r_hyd ${r_hyd} r_nuc ${r_nuc} nuc_mode 1 sigma ${sigma_tm} noise ${noise_tm} maxtrials ${maxtrials} overlap ${overlap_tm} temp 1.0 ptype ${ptype_tm} btype ${btype_tm} atype ${atype_tm} seed ${seed_tm}
fix                 fLang all langevin 1.0 1.0 1.0 ${seed}
fix                 fNVE all nve

variable            realtime equal step*${tstep}

compute             cprop all property/atom d_birth_time i_filpos
dump                1 all custom ${dump_time} traj.xyz id mol type x y z c_cprop[*]
dump_modify         1 format line "%d %d %d %.2f %.2f %.2f %.2f %d"

thermo              ${dump_time}
thermo_style        custom step v_realtime temp pe ke etotal epair ebond eangle press vol density atoms

compute             cBonds all property/local batom1 batom2 btype
compute             cBondDxys all bond/local engpot force dist

dump                2 all local ${dump_time} bonds.out c_cBonds[*] c_cBondDxys[*]
dump_modify         2 format line "%f %f %f %.2f %.2f %.2f"

fix                 twodim all enforce2d

timestep            ${tstep}
run                 ${run_steps}